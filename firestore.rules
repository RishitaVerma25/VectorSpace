rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow reading user profiles to find emails for sharing
      allow read: if request.auth != null;
      // Allow user to write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /vault/data {
        // Only the owner can read/write their vault
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /vault/shared/{workspaceId} {
        // Owner can read and write shared items
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // Anyone authenticated can share (create/update) a workspace into another user's shared collection
        allow create, update: if request.auth != null;
      }
    }
  }
}
